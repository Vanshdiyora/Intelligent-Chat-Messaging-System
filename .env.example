# Application
APP_NAME=Intelligent Chat Messaging System
DEBUG=true

# Database
DATABASE_URL=sqlite:///./chat.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/chatdb

# JWT
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
FRONTEND_URL=http://localhost:5173

# AI Models Path
MODEL_DIR=ai/saved_models
